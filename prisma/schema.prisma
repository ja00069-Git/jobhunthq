generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Application {
  id          String   @id @default(cuid())
  company     String
  role        String
  status      String
  location    String?
  salary      Int?
  dateApplied DateTime
  notes       String?
  createdAt   DateTime @default(now())
}